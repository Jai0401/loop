# Slack (Socket Mode — easiest for dev)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Anthropic (works with the official API or any compatible proxy)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_AUTH_TOKEN=sk-...            # optional, used when ANTHROPIC_API_KEY is unset (proxy)
ANTHROPIC_BASE_URL=https://api.anthropic.com   # optional, override for proxies
ANTHROPIC_MODEL=claude-sonnet-4-6

# Storage
DATABASE_PATH=./data/loop.db

# Logging
LOG_LEVEL=INFO