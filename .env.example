# Slack (Socket Mode — easiest for dev)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Slack (HTTP Mode — for production)
# SLACK_SIGNING_SECRET=...
# SLACK_BOT_TOKEN=xoxb-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Storage
DATABASE_PATH=./data/loop.db

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# MCP Server
MCP_TRANSPORT=http          # or 'stdio'
MCP_HTTP_PORT=3001
MCP_HTTP_PATH=/mcp

# Feature flags
LOOP_PROACTIVE_DM=true
LOOP_PROACTIVE_SURFACE=true
